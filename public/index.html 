<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prince AI - Your Royal Assistant</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-container">
        <!-- Welcome Screen -->
        <div id="welcome-screen" class="welcome-screen">
            <div class="welcome-content">
                <div class="crown-icon">👑</div>
                <h1>Prince AI</h1>
                <p>Your Royal Digital Companion</p>
                <button class="start-btn" onclick="startChat()">Enter the Kingdom</button>
            </div>
        </div>

        <!-- Main Chat Interface -->
        <div id="chat-interface" class="chat-interface hidden">
            <!-- Top Bar -->
            <header class="top-bar">
                <div class="ai-info">
                    <div class="ai-avatar">
                        <span>🤴</span>
                        <div class="status-dot"></div>
                    </div>
                    <div class="ai-details">
                        <h2>Prince AI</h2>
                        <span class="status-text">Online • Ready to serve</span>
                    </div>
                </div>
                <div class="header-actions">
                    <button class="icon-btn" id="theme-toggle" title="Toggle Theme">🌙</button>
                    <button class="icon-btn" id="clear-chat" title="Clear Chat">🗑️</button>
                </div>
            </header>

            <!-- Chat Area -->
            <div class="chat-container" id="chat-container">
                <div class="messages" id="messages">
                    <div class="message ai-message welcome-message">
                        <div class="avatar">🤴</div>
                        <div class="bubble">
                            <p>Greetings, noble user! I am Prince AI, your royal assistant. How may I serve you today? 👑</p>
                            <span class="timestamp">Just now</span>
                        </div>
                    </div>
                </div>
                <div class="typing-indicator hidden" id="typing-indicator">
                    <div class="avatar">🤴</div>
                    <div class="typing-bubble">
                        <div class="dots">
                            <span></span><span></span><span></span>
                        </div>
                        <span class="typing-text">Prince AI is thinking...</span>
                    </div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="input-area">
                <div class="input-wrapper">
                    <button class="mic-btn" id="mic-btn" title="Voice Input">🎤</button>
                    <input type="text" id="user-input" placeholder="Ask Prince AI anything..." autocomplete="off">
                    <button class="send-btn" id="send-btn" title="Send Message">➤</button>
                </div>
                <div class="input-hint">Press Enter to send • Click 🎤 for voice</div>
            </div>
        </div>
    </div>


    <script src="script.js"></script>
</body>
</html>
